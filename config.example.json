{
  "openai": {
    "apiKey": "sk-REPLACE-ME",
    "baseUrl": "xxx",
    "model": "gpt-5.5",
    "modelProvider": "openai",
    "modelProviderName": "OpenAI",
    "wireApi": "responses",
    "supportsWebsockets": false
  },
  "chatModel": {
    "apiKey": "EMPTY",
    "baseUrl": "xxx",
    "model": "gpt-5.5",
    "modelReasoningEffort": "low",
    "approvalPolicy": "never",
    "sandboxMode": "read-only",
    "skipGitRepoCheck": true
  },
  "auth": {
    "enabled": false,
    "headerName": "x-codex-user-id",
    "cookieName": "codex_user_id",
    "devUserId": "default",
    "usersDir": "users"
  },
  "codex": {
    "modelReasoningEffort": "low",
    "approvalPolicy": "never",
    "sandboxMode": "workspace-write",
    "sandboxWorkspaceWriteNetworkAccess": true,
    "skipGitRepoCheck": true
  },
  "server": {
    "port": 3102,
    "host": "0.0.0.0"
  },
  "frontend": {
    "host": "0.0.0.0",
    "publicHost": "localhost",
    "port": 5274,
    "httpsPort": 5275,
    "strictPort": true
  },
  "tmux": {
    "backendSession": "ocw-backend",
    "frontendSession": "ocw-frontend"
  },
  "tools": {
    "remoteDesktopLauncher": "/usr/local/bin/start-remote-cad-desktop",
    "cad": {
      "displayNum": ":1",
      "launcher": "/usr/local/bin/start-freecad-remote",
      "bin": "/path/to/freecad",
      "vncPort": 5901,
      "noVncPort": 6080
    },
    "paraview": {
      "displayNum": ":2",
      "launcher": "/usr/local/bin/start-paraview-remote",
      "vncPort": 5902,
      "noVncPort": 6081
    },
    "comsol": {
      "displayNum": ":32",
      "launcher": "/usr/local/bin/start-comsol-remote",
      "sudo": "sudo",
      "vncPort": 5932,
      "noVncPort": 6082
    },
    "gnc": {
      "url": "http://localhost:8765/"
    }
  },
  "gnc": {
    "dashboard": {
      "telemetryMaxBytes": 8388608,
      "telemetryPaths": {
        "time": "02_sim/42_run/runtime_case/InOut/time.42",
        "wbn": "02_sim/42_run/runtime_case/InOut/wbn.42",
        "qbn": "02_sim/42_run/runtime_case/InOut/qbn.42",
        "posn": "02_sim/42_run/runtime_case/InOut/PosN.42",
        "veln": "02_sim/42_run/runtime_case/InOut/VelN.42",
        "hwhl": "02_sim/42_run/runtime_case/InOut/Hwhl.42",
        "mtb": "02_sim/42_run/runtime_case/InOut/MTB.42",
        "modeSummary": "AIGNC_Workflow/08_run/run_summary.json"
      }
    }
  },
  "whisper": {
    "modelPath": "/path/to/whisper/model.bin",
    "ffmpegBin": "ffmpeg",
    "cudaVisibleDevices": null,
    "defaultLanguage": "zh-en"
  },
  "cosyvoice": {
    "apiUrl": "http://127.0.0.1:50000/inference_zero_shot",
    "promptText": "You are a helpful assistant.<|endofprompt|>希望你以后能够做的比我还好呦。",
    "streamCacheTtlMs": 600000,
    "streamCacheMaxItems": 64,
    "ttsMaxTextLength": 5000
  },
  "workflowAgents": {
    "contractDir": "/path/to/open_codex_web/backend/workflow_agents",
    "plannerMode": "codex",
    "plannerModel": "gpt-5.5",
    "plannerReasoningEffort": "high",
    "plannerWorkingDirectory": "/path/to/your/workspace",
    "plannerTimeoutMs": 120000,
    "plannerSandboxMode": "read-only",
    "plannerSkipGitRepoCheck": true
  },
  "logging": {
    "level": "info",
    "file": "logs/app.log",
    "alsoStdout": true
  },
  "workspace": {
    "templateDir": "/path/to/open_codex_web/data/input_data",
    "usersRoot": "/path/to/codex_web/data/users",
    "filesystemGroup": "users",
    "rpcHost": "localhost",
    "rpcPort": 9877,
    "componentInfoMaxStepSizeMb": 5,
    "filePreviewMaxBytes": 5242880,
    "textFileMaxBytes": 67108864,
    "textChunkBytes": 1048576,
    "textChunkMaxBytes": 2097152
  }
}
