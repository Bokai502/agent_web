  },
  "chatModel": {
    "apiKey": "xxx",
    "_apiKeyComment": "填写默认内网模型服务的 API Key",
    "baseUrl": "http://10.110.34.83:4000/v1",
    "model": "Qwen3.6"
  },
  "server": {
    "port": 3002,
    "host": "0.0.0.0"
  },
  "tmux": {
    "backendSession": "xxx",
    "_backendSessionComment": "填写后端 tmux 会话名，例如 ocw-main-backend",
    "frontendSession": "xxx",
    "_frontendSessionComment": "填写前端 tmux 会话名，例如 ocw-main-frontend"
  },
  "frontend": {
    "host": "0.0.0.0",
    "publicHost": "10.110.10.11",
    "port": 5174,
    "httpsPort": 5175,
    "strictPort": true
  },
  "workspace": {
    "templateDir": "xxx",
    "_templateDirComment": "填写示例输入/工作区模板目录，例如 /data/lbk/codex_web/open_codex_web/data/input_data",
    "usersRoot": "xxx",
    "_usersRootComment": "填写用户工作区根目录，例如 /data/lbk/codex_web/data/users",
    "filesystemGroup": "xieteam",
    "rpcHost": "localhost",
    "rpcPort": 9877,
    "componentInfoMaxStepSizeMb": 6.5,
    "filePreviewMaxBytes": 5242880,
    "textFileMaxBytes": 67108864,
    "textChunkBytes": 1048576,
    "textChunkMaxBytes": 2097152
  },
  "compliance": {
    "database": {
      "host": "10.110.10.101",
      "port": "5432",
      "user": "postgres",
      "password": "xxx",
      "_passwordComment": "填写 PostgreSQL 数据库密码",
      "catalog": {
        "db": "components_db",
        "recallLimitPerComponent": 80
      },
      "reliability": {
        "db": "satllm_db",
        "schema": "staging",
        "limitPerComponent": 5
      }
    }
  },
  "codex": {
    "modelProvider": "nexahub",
    "modelProviderName": "NexaHub",
    "wireApi": "responses",
    "supportsWebsockets": false,
    "modelReasoningEffort": "high",
    "approvalPolicy": "never",
    "sandboxMode": "workspace-write",
    "sandboxWorkspaceWriteNetworkAccess": true,
    "skipGitRepoCheck": true
  },
  "tools": {
    "remoteDesktopLauncher": "/usr/local/bin/start-remote-cad-desktop",
    "cad": {
      "displayNum": ":1",
      "launcher": "/usr/local/bin/start-freecad-remote",
      "bin": "/usr/bin/freecad",
      "vncPort": 5901,
      "noVncPort": 6080
    },
    "paraview": {
      "displayNum": ":2",
      "launcher": "/usr/local/bin/start-paraview-remote",
      "vncPort": 5902,
      "noVncPort": 6081
    },
    "comsol": {
      "displayNum": ":32",
      "launcher": "/usr/local/bin/start-comsol-remote",
      "sudo": "sudo",
      "vncPort": 5932,
      "noVncPort": 6082
    },
    "gnc": {
      "url": "http://localhost:8765/"
    }
  },
  "funasr": {
    "apiUrl": "http://127.0.0.1:18080/v1/audio/transcriptions"
  },
  "cosyvoice": {
    "apiUrl": "http://127.0.0.1:50000/inference_zero_shot",
    "promptText": "You are a helpful assistant.<|endofprompt|>希望你以后能够做的比我还好呦。",
    "streamCacheTtlMs": 600000,
    "streamCacheMaxItems": 64,
    "ttsMaxTextLength": 5000
  },
  "auth": {
    "enabled": false,
    "headerName": "x-codex-user-id",
    "cookieName": "codex_user_id",
    "devUserId": "default",
    "usersDir": "users"
  },
  "gnc": {
    "dashboard": {
      "telemetryMaxBytes": 8388608,
      "telemetryPaths": {
        "time": "02_sim/42_run/runtime_case/InOut/time.42",
        "wbn": "02_sim/42_run/runtime_case/InOut/wbn.42",
        "qbn": "02_sim/42_run/runtime_case/InOut/qbn.42",
        "posn": "02_sim/42_run/runtime_case/InOut/PosN.42",
        "veln": "02_sim/42_run/runtime_case/InOut/VelN.42",
        "hwhl": "02_sim/42_run/runtime_case/InOut/Hwhl.42",
        "mtb": "02_sim/42_run/runtime_case/InOut/MTB.42",
        "modeSummary": "AIGNC_Workflow/08_run/run_summary.json"
      }
    }
  },
  "logging": {
    "level": "info",
    "file": "logs/app.log",
    "alsoStdout": true
  }
}
